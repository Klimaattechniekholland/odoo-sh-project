<odoo>
  <record id="view_ai_assistant_settings" model="ir.ui.view">
    <field name="name">ai.assistant.settings.form</field>
    <field name="model">res.config.settings</field>
    <field name="arch" type="xml">
      <form string="AI Assistent Instellingen">
        <group>
          <field name="openai_api_key"/>
          <field name="gemini_api_key"/>
        </group>
        <footer>
          <button type="object" name="execute" string="Save" class="btn-primary"/>
          <button string="Discard" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>

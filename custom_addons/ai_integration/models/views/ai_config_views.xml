<odoo>
  <record id="view_ai_config_form" model="ir.ui.view">
    <field name="name">ai.integration.config.settings</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet" position="inside">
        <group string="AI Integration">
          <field name="api_key" placeholder="Voer hier je AI API-key in..."/>
        </group>
        <group string="AI Chat">
          <div t-call="ai_integration.AIWidget"/>
        </group>
      </xpath>
    </field>
  </record>
</odoo>
